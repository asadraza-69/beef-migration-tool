#!/usr/bin/env sh
set -eu

if command -v php >/dev/null 2>&1; then
  exec php tests/run.php "$@"
fi

if command -v docker >/dev/null 2>&1; then
  exec docker compose -f docker-compose.test.yml run --rm php-test php tests/run.php "$@"
fi

echo "No local php binary and no docker installation found." >&2
exit 1
